@page
@model IndexModel
@{
    ViewData["Title"] = "Phân tích nhật ký lỗi";
}

<div class="logmount-page">
    <div class="page-header mb-4">
        <h1 class="h2 mb-1">Phân tích nhật ký lỗi</h1>
        <p class="text-muted mb-0">Tải lên một hoặc nhiều tệp nhật ký (.csv, .xlsx, .xls) — hỗ trợ tối đa 200 MB/tệp, tổng 500 MB.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    <div class="card shadow-sm mb-4 border-primary">
        <div class="card-body">
            <h2 class="h5 card-title">Lấy nhật ký lỗi theo ngày</h2>
            <p class="text-muted small mb-3">
                Chọn ngày; hệ thống sẽ cập nhật tên <code>RetryLogyyyyMMdd.csv</code> trong tệp batch,
                chạy tổng hợp và tự nạp tệp kết quả.
            </p>
            <form method="post" asp-page-handler="LoadRetryLog" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label asp-for="RetryLogDate" class="form-label">Ngày log</label>
                    <input asp-for="RetryLogDate" type="date" class="form-control" required />
                </div>
                <div class="col-md-8">
                    <button type="submit" class="btn btn-success">Tổng hợp &amp; tải nhật ký lỗi</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h2 class="h5 card-title">Tải tệp nhật ký lỗi</h2>
            <form id="log-upload-form" method="post" asp-page-handler="Upload" enctype="multipart/form-data" class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label asp-for="UploadFiles" class="form-label">Chọn một hoặc nhiều tệp (.csv, .xlsx, .xls)</label>
                    <input id="log-upload-input" asp-for="UploadFiles" type="file" class="form-control" accept=".csv,.xlsx,.xls" multiple />
                    <div class="form-text">Chọn nhiều tệp cùng lúc hoặc chọn từng tệp — danh sách sẽ được cộng dồn bên dưới.</div>
                    <ul id="log-upload-file-list" class="upload-file-list list-group list-group-flush mt-2 small d-none"></ul>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Tải lên &amp; đọc dữ liệu</button>
                    @if (Model.HasData)
                    {
                        <button type="submit" formaction="?handler=Clear" formmethod="post" class="btn btn-outline-danger"
                                onclick="return confirm('Xóa dữ liệu đã tải lên?');">
                            Xóa dữ liệu
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h2 class="h5 card-title">Tải tệp linh kiện đắt tiền</h2>
            <p class="text-muted small mb-3">
                Tệp Excel/CSV chứa danh sách mã linh kiện ở cột A (ví dụ: <code>part lkdt.xlsx</code>).
            </p>
            <form method="post" asp-page-handler="UploadPart" enctype="multipart/form-data" class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label asp-for="PartListFile" class="form-label">Chọn tệp linh kiện đắt tiền (.xlsx, .xls, .csv)</label>
                    <input asp-for="PartListFile" type="file" class="form-control" accept=".csv,.xlsx,.xls" required />
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Tải linh kiện đắt tiền</button>
                    @if (Model.HasPartData)
                    {
                        <button type="submit" formaction="?handler=ClearPart" formmethod="post" class="btn btn-outline-danger"
                                onclick="return confirm('Xóa tệp linh kiện đắt tiền đã tải lên?');">
                            Xóa linh kiện đắt tiền
                        </button>
                    }
                </div>
            </form>

            @if (Model.HasPartData)
            {
                <div class="alert alert-success mt-3 mb-0 py-2">
                    <strong>Đã nạp linh kiện đắt tiền:</strong> @Model.UploadedPartFileName —
                    <strong>@Model.UploadedPartCount.ToString("N0")</strong> linh kiện đắt tiền.
                </div>
            }
        </div>
    </div>

    @if (Model.CanSummarizeExpensiveParts)
    {
        <div class="card shadow-sm mb-4 border-primary">
            <div class="card-body d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h2 class="h5 mb-1">Tổng hợp linh kiện đắt tiền</h2>
                </div>
                <a asp-page="/ExpensiveParts" class="btn btn-success btn-lg">Tổng hợp</a>
            </div>
        </div>
    }
    else if (Model.HasData || Model.HasPartData)
    {
        <div class="alert alert-warning mb-4">
            @if (!Model.HasData)
            {
                <span>Vui lòng tải tệp nhật ký lỗi.</span>
            }
            else if (!Model.HasPartData)
            {
                <span>Vui lòng tải tệp linh kiện đắt tiền để tổng hợp.</span>
            }
        </div>
    }

    @if (Model.HasData)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <div>
                        <h2 class="h5 mb-1">Tìm kiếm &amp; tổng hợp lỗi</h2>
                    </div>
                </div>

                <form method="get" class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="Filter.Date" class="form-label">Ngày</label>
                        <input asp-for="Filter.Date" class="form-control" placeholder="VD: 18/12/2024" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.Line" class="form-label">Line</label>
                        <input asp-for="Filter.Line" class="form-control" placeholder="VD: L1-B-A" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.OccurrenceTime" class="form-label">Occurrence Time</label>
                        <input asp-for="Filter.OccurrenceTime" class="form-control" placeholder="VD: 2026/07/18" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.LotName" class="form-label">Lot Name</label>
                        <input asp-for="Filter.LotName" class="form-control" placeholder="VD: EBR25938" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.ErrorNo" class="form-label">Mã lỗi</label>
                        <input asp-for="Filter.ErrorNo" class="form-control" placeholder="VD: 31" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.ErrorName" class="form-label">Tên lỗi</label>
                        <input asp-for="Filter.ErrorName" class="form-control" placeholder="VD: PICK UP ERROR" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.Lane" class="form-label">Lane</label>
                        <input asp-for="Filter.Lane" class="form-control" placeholder="VD: 1" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.Table" class="form-label">Table</label>
                        <input asp-for="Filter.Table" class="form-control" placeholder="VD: A" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.PartsNo" class="form-label">Parts No.</label>
                        <input asp-for="Filter.PartsNo" class="form-control" placeholder="VD: 50" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.PartsName" class="form-label">Parts Name</label>
                        <input asp-for="Filter.PartsName" class="form-control" placeholder="VD: EBC64038607" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.HeadNo" class="form-label">Head No.</label>
                        <input asp-for="Filter.HeadNo" class="form-control" placeholder="VD: 11" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.NozzleType" class="form-label">Nozzle Type</label>
                        <input asp-for="Filter.NozzleType" class="form-control" placeholder="VD: TYPE-512" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.FeederNo" class="form-label">Feeder No.</label>
                        <input asp-for="Filter.FeederNo" class="form-control" placeholder="VD: 112" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.FeederId" class="form-label">Feeder ID</label>
                        <input asp-for="Filter.FeederId" class="form-control" placeholder="VD: ZSY-008-0044951A" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.CartId" class="form-label">Cart ID</label>
                        <input asp-for="Filter.CartId" class="form-control" placeholder="VD: CTS$46$" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.VisErrorNo" class="form-label">Vis Error No.</label>
                        <input asp-for="Filter.VisErrorNo" class="form-control" placeholder="VD: VE150" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.ErrorVacuum" class="form-label">Error Vacuum</label>
                        <input asp-for="Filter.ErrorVacuum" class="form-control" placeholder="VD: 165" />
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                        <a asp-page="./Index" class="btn btn-outline-secondary">Xóa bộ lọc</a>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.FilteredRecords > 0 && Model.ErrorSummary.Count > 0)
        {
            @if (Model.IsFiltered)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <h2 class="h5 card-title mb-1">Thông tin tổng quan (kết quả lọc)</h2>
                                <p class="text-muted small mb-0">Giá trị khác nhau trong từng cột của dữ liệu đã lọc.</p>
                            </div>
                            <partial name="_ExportButtons" model='("Overview", Model)' />
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-secondary">
                                    <tr>
                                        <th style="width: 160px;">Cột</th>
                                        <th>Giá trị</th>
                                        <th style="width: 100px;" class="text-end">Số giá trị</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var col in Model.ColumnSummary)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@col.ColumnName</td>
                                            <td>@col.Values</td>
                                            <td class="text-end">@col.DistinctCount.ToString("N0")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <h2 class="h5 card-title mb-1">@(Model.IsFiltered ? "Tổng hợp lỗi (kết quả lọc)" : "Tổng hợp lỗi (toàn bộ tệp)")</h2>
                            <p class="text-muted small mb-0">
                                @(Model.IsFiltered
                                    ? "Số lần xuất hiện của từng loại lỗi theo điều kiện tìm kiếm."
                                    : "Số lần xuất hiện của từng loại lỗi trong toàn bộ tệp. Nhập tên linh kiện / số bộ cấp liệu ở trên để lọc chi tiết hơn.")
                            </p>
                        </div>
                        <partial name="_ExportButtons" model='("Errors", Model)' />
                    </div>
                    <div class="table-responsive summary-table-wrapper">
                        <table class="table table-sm table-striped table-hover align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Mã lỗi</th>
                                    <th>Tên lỗi</th>
                                    <th class="text-end">Số lần</th>
                                    <th>Ngày</th>
                                    <th>Line</th>
                                    <th>Occurrence Time</th>
                                    <th>Lot Name</th>
                                    <th>Lane</th>
                                    <th>Table</th>
                                    <th>Parts No.</th>
                                    <th>Parts Name</th>
                                    <th>Head No.</th>
                                    <th>Nozzle Type</th>
                                    <th>Feeder No.</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ErrorSummary)
                                {
                                    <tr>
                                        <td>@item.ErrorNo</td>
                                        <td class="error-name-cell">
                                            <span class="@IndexModel.GetErrorNameCssClass(item.ErrorName)">@item.ErrorName</span>
                                        </td>
                                        <td class="text-end fw-semibold">@item.Count.ToString("N0")</td>
                                        <td>@item.Dates</td>
                                        <td>@item.Lines</td>
                                        <td>@item.OccurrenceTimes</td>
                                        <td>@item.LotNames</td>
                                        <td>@item.Lanes</td>
                                        <td>@item.Tables</td>
                                        <td>@item.PartsNumbers</td>
                                        <td>@item.PartsNames</td>
                                    <td>@item.HeadNumbers</td>
                                    <td>@item.NozzleTypes</td>
                                    <td>@item.FeederNumbers</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-secondary fw-semibold">
                                    <td colspan="2">Tổng cộng</td>
                                    <td class="text-end">@Model.ErrorSummary.Sum(x => x.Count).ToString("N0")</td>
                                    <td colspan="11"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        }
        else if (Model.IsFiltered)
        {
            <div class="alert alert-warning">Không tìm thấy dữ liệu phù hợp với điều kiện tìm kiếm.</div>
        }

        <div class="card shadow-sm" id="log-data-section">
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <h2 class="h5 card-title mb-1">Dữ liệu log</h2>
                    </div>
                    <partial name="_ExportButtons" model='("Logs", Model)' />
                </div>
                <div class="table-responsive log-table-wrapper">
                    <table class="table table-sm table-bordered table-hover align-middle mb-0">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Ngày</th>
                                <th>Line</th>
                                <th>Occurrence Time</th>
                                <th>Mã lỗi</th>
                                <th>Tên lỗi</th>
                                <th>Lane</th>
                                <th>Table</th>
                                <th>Parts No.</th>
                                <th>Parts Name</th>
                                <th>Head No.</th>
                                <th>Nozzle Type</th>
                                <th>Feeder No.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.DisplayEntries)
                            {
                                <tr>
                                    <td>@row.Date</td>
                                    <td>@row.Line</td>
                                    <td>@row.OccurrenceTime</td>
                                    <td>@row.ErrorNo</td>
                                    <td class="error-name-cell">
                                        @if (string.IsNullOrWhiteSpace(row.ErrorName))
                                        {
                                            <span class="error-name-tag error-name-empty">—</span>
                                        }
                                        else
                                        {
                                            <span class="@IndexModel.GetErrorNameCssClass(row.ErrorName)">@row.ErrorName</span>
                                        }
                                    </td>
                                    <td>@row.Lane</td>
                                    <td>@row.Table</td>
                                    <td>@row.PartsNo</td>
                                    <td>@row.PartsName</td>
                                    <td>@row.HeadNo</td>
                                    <td>@row.NozzleType</td>
                                    <td>@row.FeederNo</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    var visiblePages = Enumerable.Range(1, Model.TotalPages)
                        .Where(page => page <= 2 ||
                                       page >= Model.TotalPages - 1 ||
                                       Math.Abs(page - Model.PageNumber) <= 2)
                        .ToList();
                    var previousPage = 0;

                    <nav class="mt-3" aria-label="Phân trang">
                        <ul class="pagination pagination-sm justify-content-center mb-0">
                            <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-page="./Index" asp-all-route-data="@Model.GetPaginationRouteValues(Model.PageNumber - 1)">Trước</a>
                            </li>
                            @foreach (var page in visiblePages)
                            {
                                @if (page - previousPage > 1)
                                {
                                    <li class="page-item disabled" aria-hidden="true">
                                        <span class="page-link">…</span>
                                    </li>
                                }
                                <li class="page-item @(page == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" asp-page="./Index" asp-all-route-data="@Model.GetPaginationRouteValues(page)">@(page)</a>
                                </li>
                                previousPage = page;
                            }
                            <li class="page-item @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-page="./Index" asp-all-route-data="@Model.GetPaginationRouteValues(Model.PageNumber + 1)">Sau</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    }
</div>
