<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LogMount</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LogMount.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
        var isAnalysisPage = currentPage.Equals("/Index", StringComparison.OrdinalIgnoreCase) ||
                             currentPage.Equals("/ExpensiveParts", StringComparison.OrdinalIgnoreCase);
        var isDataByDatePage = currentPage.Equals("/DataByDate", StringComparison.OrdinalIgnoreCase);
    }

    <div class="app-shell">
        <aside class="app-sidebar">
            <a class="sidebar-brand" asp-area="" asp-page="/Index">LogMount</a>
            <nav class="sidebar-nav" aria-label="Dashboard">
                <a class="sidebar-link @(isAnalysisPage ? "active" : "")" asp-area="" asp-page="/Index">
                    <span class="sidebar-link-title">Phân tích retryLog</span>
                    <span class="sidebar-link-subtitle">Tải lên, lọc và tổng hợp lỗi</span>
                </a>
                <a class="sidebar-link @(isDataByDatePage ? "active" : "")" asp-area="" asp-page="/DataByDate">
                    <span class="sidebar-link-title">Xem dữ liệu theo ngày</span>
                    <span class="sidebar-link-subtitle">Xem dữ liệu đã tải lên trong CSDL</span>
                </a>
            </nav>
        </aside>

        <main role="main" class="app-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
