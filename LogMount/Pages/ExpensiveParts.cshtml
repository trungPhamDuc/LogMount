@page
@model ExpensivePartsModel
@{
    ViewData["Title"] = "Tổng hợp linh kiện đắt tiền";
}

<div class="logmount-page">
    <div class="page-header mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
            <div>
                <h1 class="h2 mb-1">Tổng hợp linh kiện đắt tiền</h1>
                <p class="text-muted mb-0">
                    So sánh part name trong file part lkdt với dữ liệu retry log đã upload.
                </p>
            </div>
            <a asp-page="/Index" class="btn btn-outline-secondary">← Quay lại</a>
        </div>
    </div>

    <div class="alert alert-info mb-4">
        <div><strong>File log:</strong> @Model.LogFileName — @Model.LogRecordCount.ToString("N0") dòng</div>
        <div><strong>File part lkdt:</strong> @Model.PartFileName — @Model.PartCount.ToString("N0") linh kiện</div>
        <div>
            <strong>Kết quả khớp:</strong> @Model.Summary.Count.ToString("N0") nhóm lỗi — tổng @Model.TotalErrorCount.ToString("N0") lần
            @if (Model.IsFiltered)
            {
                <span>— Sau lọc: <strong>@Model.FilteredSummary.Count.ToString("N0")</strong> nhóm, <strong>@Model.FilteredErrorCount.ToString("N0")</strong> lần</span>
            }
        </div>
    </div>

    @if (Model.Summary.Count == 0)
    {
        <div class="alert alert-warning">
            Không tìm thấy lỗi nào liên quan đến linh kiện đắt tiền trong dữ liệu retry log.
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h2 class="h5 card-title mb-3">Lọc &amp; sắp xếp</h2>
                <form method="get" class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="Filter.PartsName" class="form-label">Parts Name</label>
                        <input asp-for="Filter.PartsName" class="form-control" placeholder="VD: EAG65195601" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Filter.Line" class="form-label">Line</label>
                        <input asp-for="Filter.Line" class="form-control" placeholder="VD: L1" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Filter.Machine" class="form-label">Máy</label>
                        <input asp-for="Filter.Machine" class="form-control" placeholder="VD: G" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Filter.ErrorName" class="form-label">Error Name</label>
                        <input asp-for="Filter.ErrorName" class="form-control" placeholder="VD: PICK UP ERROR" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Filter.SortDirection" class="form-label">Sắp xếp bảng</label>
                        <select asp-for="Filter.SortDirection" class="form-select">
                            <option value="location">Line → Mặt → Máy</option>
                            <option value="desc">Số lần: Lớn → Nhỏ</option>
                            <option value="asc">Số lần: Nhỏ → Lớn</option>
                            <option value="cost-desc">Tổng giá tiền: Lớn → Nhỏ</option>
                            <option value="cost-asc">Tổng giá tiền: Nhỏ → Lớn</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="TopN" class="form-label">Top linh kiện</label>
                        <select asp-for="TopN" class="form-select">
                            @foreach (var option in Model.TopNChoices)
                            {
                                <option value="@option">Top @option</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Áp dụng</button>
                        <a asp-page="./ExpensiveParts" class="btn btn-outline-secondary">Xóa bộ lọc</a>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.TopParts.Count > 0)
        {
            <div class="row g-4 mb-4">
                <div class="col-lg-7">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h2 class="h5 card-title mb-1">Biểu đồ Top @Model.TopN linh kiện rơi nhiều nhất</h2>
                            <p class="text-muted small mb-3">Tổng số lần lỗi theo part name (sau khi lọc).</p>
                            <div class="chart-wrapper">
                                <canvas id="topPartsChart" aria-label="Biểu đồ top linh kiện"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h2 class="h5 card-title mb-1">Thống kê Top @Model.TopN</h2>
                            <p class="text-muted small mb-3">Xếp hạng linh kiện đắt tiền rơi nhiều nhất.</p>
                            <div class="table-responsive">
                                <table class="table table-sm table-striped align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 48px;">#</th>
                                            <th>Parts Name</th>
                                            <th class="text-end">Số lần</th>
                                            <th class="text-end">Giá 1 con</th>
                                            <th class="text-end">Tổng giá tiền</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.TopParts)
                                        {
                                            <tr>
                                                <td class="fw-semibold">@item.Rank</td>
                                                <td>
                                                    <button type="button"
                                                            class="btn p-0 fw-semibold text-start part-name-filter"
                                                            data-part-name="@item.PartsName">
                                                        @item.PartsName
                                                    </button>
                                                </td>
                                                <td class="text-end fw-semibold text-danger">@item.TotalCount.ToString("N0")</td>
                                                <td class="text-end text-muted">@item.Cost.ToString("N2")</td>
                                                <td class="text-end fw-semibold text-danger">@item.TotalCost.ToString("N2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card shadow-sm" id="part-details">
            <div class="card-body">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <h2 class="h5 card-title mb-1">Chi tiết lỗi theo linh kiện đắt tiền</h2>
                        <p class="text-muted small mb-0">
                            @Model.FilteredSummary.Count.ToString("N0") dòng —
                            @(Model.Filter.IsCostSort
                                ? $"sắp xếp theo tổng giá tiền {(Model.Filter.IsCostDescending ? "giảm dần" : "tăng dần")}."
                                : Model.Filter.IsCountSort
                                ? $"sắp xếp theo số lần {(Model.Filter.IsDescending ? "giảm dần" : "tăng dần")}."
                                : "sắp xếp theo Line, Mặt (Bot → Top), rồi Máy (A → Z).")
                        </p>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-page="./ExpensiveParts" asp-page-handler="Export" asp-route-format="Csv"
                           asp-all-route-data="@Model.GetExportRouteValues("Csv")"
                           class="btn btn-sm btn-outline-success">Tải CSV</a>
                        <a asp-page="./ExpensiveParts" asp-page-handler="Export" asp-route-format="Xlsx"
                           asp-all-route-data="@Model.GetExportRouteValues("Xlsx")"
                           class="btn btn-sm btn-outline-success">Tải Excel</a>
                    </div>
                </div>

                @if (Model.FilteredSummary.Count == 0)
                {
                    <div class="alert alert-warning mb-0">Không có dữ liệu phù hợp với bộ lọc.</div>
                }
                else
                {
                    <div class="table-responsive summary-table-wrapper">
                        <table class="table table-sm table-striped table-hover align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Parts Name</th>
                                    <th>Line</th>
                                    <th>Mặt</th>
                                    <th>Máy</th>
                                    <th>Lane</th>
                                    <th>Feeder</th>
                                    <th>Error No.</th>
                                    <th>Error Name</th>
                                    <th class="text-end">Tổng giá tiền</th>
                                    <th class="text-end">Số lần</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.FilteredSummary)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.PartsName</td>
                                        <td>@item.Line</td>
                                        <td>@item.SideLabel (@item.Side)</td>
                                        <td>@item.Machine</td>
                                        <td>@item.Lane</td>
                                        <td>@item.FeederNo</td>
                                        <td>@item.ErrorNo</td>
                                        <td class="error-name-cell">
                                            <span class="@IndexModel.GetErrorNameCssClass(item.ErrorName)">@item.ErrorName</span>
                                        </td>
                                        <td class="text-end fw-semibold text-danger">@item.TotalCost.ToString("N2")</td>
                                        <td class="text-end fw-semibold">@item.Count.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-secondary fw-semibold">
                                    <td colspan="8">Tổng cộng (đã lọc)</td>
                                    <td class="text-end text-danger">@Model.FilteredSummary.Sum(item => item.TotalCost).ToString("N2")</td>
                                    <td class="text-end">@Model.FilteredErrorCount.ToString("N0")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            document.querySelectorAll('.part-name-filter').forEach(function (button) {
                button.addEventListener('click', function () {
                    var parameters = new URLSearchParams(window.location.search);
                    parameters.set('Filter.PartsName', button.dataset.partName);
                    window.location.href = window.location.pathname + '?' + parameters.toString() + '#part-details';
                });
            });

            var chartCanvas = document.getElementById('topPartsChart');
            if (!chartCanvas) {
                return;
            }

            var chartData = @Html.Raw(Model.ChartDataJson);
            if (!chartData.length) {
                return;
            }

            var labels = chartData.map(function (item) { return item.partsName; });
            var values = chartData.map(function (item) { return item.totalCount; });

            new Chart(chartCanvas, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Số lần lỗi',
                        data: values,
                        backgroundColor: 'rgba(220, 53, 69, 0.75)',
                        borderColor: 'rgba(220, 53, 69, 1)',
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return ' ' + context.parsed.x.toLocaleString('vi-VN') + ' lần';
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            },
                            title: {
                                display: true,
                                text: 'Số lần'
                            }
                        },
                        y: {
                            ticks: {
                                autoSkip: false
                            }
                        }
                    }
                }
            });
        })();
    </script>
}
